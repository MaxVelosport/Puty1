4:32:14 AM [express] GET /api/training-programs/11/exercises 200 in 544ms :: [{"id":140,"programId":11,"name":"Жим штанги лёжа","description":"Базовое упражнение для развития грудных мышц и трицепсов.","technique":"Ляг на горизонтальную скамью, ноги на полу. Возьми штангу хватом чуть шире плеч. На вдохе медленно опускай штангу к нижней части груди, локти под углом 45°. На выдохе мощно выжимай штангу вверх до полного выпрямления рук, не блокируя локти.","tips":"Не отрывай поясницу от скамьи — это снижает нагрузку на позвоночник. Не разводи локти слишком широко — береги плечевые суставы. Прогрессируй весом не более 5% в неделю.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Грудь, трицепс, передние дельты","sortOrder":0,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ. Начни с разминочного подхода на 50%.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь"},{"id":141,"programId":11,"name":"Разводка гантелей на наклонной скамье","description":"Изолирующее упражнение на верхнюю часть грудных мышц.","technique":"Ляг на скамью с углом 30°. Возьми гантели, руки над грудью. На вдохе разводи руки в стороны по широкой дуге, слегка сгибая локти. В нижней точке почувствуй растяжку грудных. На выдохе своди руки обратно, представляя обхват большого предмета.","tips":"Держи небольшой сгиб в локтях на протяжении всего движения. Не опускай гантели ниже уровня плеч. Акцент на растяжке и сокращении, а не на весе.","sets":4,"reps":"12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Верхняя часть груди","sortOrder":1,"exerciseType":"superset","weightAdvice":"Умеренный вес, который позволяет полный диапазон движения.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь"},{"id":142,"programId":11,"name":"Отжимания на брусьях","description":"Упражнение для развития грудных мышц и трицепсов с акцентом на нижнюю часть груди.","technique":"Установи руки на брусья, ноги свисают вниз. На вдохе медленно опускай тело, сгибая локти до угла 90°. На выдохе поднимайся обратно, выпрямляя руки.","tips":"Сохраняй корпус прямым, не прогибай спину. Не допускай резких движений, контролируй опускание. Увеличивай количество повторений по мере роста силы.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Грудь, трицепс","sortOrder":2,"exerciseType":"superset","weightAdvice":"Используй собственный вес тела, добавляй отягощение по мере прогресса.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь"},{"id":143,"programId":11,"name":"Жим гантелей на горизонтальной скамье","description":"Упражнение для проработки всей грудной мышцы с акцентом на её центральную часть.","technique":"Ляг на скамью, держи гантели на уровне груди. На вдохе опускай гантели в стороны, слегка сгибая локти. На выдохе поднимай гантели вверх, сводя их над грудью.","tips":"Не разводи локти слишком широко, чтобы избежать травм плеч. Сохраняй контроль над весом на протяжении всего движения. Прогрессируй с весом, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Центральная часть груди","sortOrder":3,"exerciseType":"superset","weightAdvice":"Выбирай вес, с которым можешь выполнить 10-12 повторений.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь"},{"id":144,"programId":11,"name":"Пуловер с гантелей","description":"Упражнение для растяжения и развития грудных мышц.","technique":"Ляг на скамью, держа гантель обеими руками над головой. На вдохе медленно опускай гантель за голову, сгибая локти. На выдохе поднимай гантель обратно в исходное положение.","tips":"Следи за положением локтей, они должны оставаться слегка согнутыми. Не допускай резких движений, контролируй опускание. Увеличивай вес по мере прогресса.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Грудь, трицепс","sortOrder":4,"exerciseType":"superset","weightAdvice":"Выбирай умеренный вес, позволяющий контролировать движение.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь"},{"id":145,"programId":11,"name":"Тяга штанги в наклоне","description":"Базовое упражнение для развития широчайших мышц спины.","technique":"Встань, ноги на ширине плеч, наклонись вперёд, держа штангу. На вдохе опускай штангу к коленям, сгибая локти. На выдохе поднимай штангу к животу, сводя лопатки вместе.","tips":"Не округляй спину, держи её прямой. Не поднимай штангу слишком высоко, акцент на сокращении мышц. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Широчайшие мышцы спины, трапеция","sortOrder":5,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина"},{"id":146,"programId":11,"name":"Тяга верхнего блока","description":"Упражнение для изолированной проработки широчайших мышц спины.","technique":"Сядь на тренажёр, ноги упираются в платформу. На вдохе потяни ручки к груди, сводя лопатки. На выдохе вернись в исходное положение.","tips":"Не наклоняйся слишком сильно вперёд, держи спину прямой. Контролируй движение, избегай резких рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Широчайшие мышцы спины","sortOrder":6,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина"},{"id":147,"programId":11,"name":"Тяга гантели в наклоне","description":"Упражнение для проработки одной стороны спины.","technique":"Встань в наклон, одна рука на скамье, другая с гантелью. На вдохе опусти гантель вниз, на выдохе поднимай к бедру, сводя лопатку.","tips":"Держи корпус стабильным, не вращай его. Контролируй движение, избегай рывков. Увеличивай вес по мере прогресса.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Широчайшие мышцы спины, ромбовидные","sortOrder":7,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина"},{"id":148,"programId":11,"name":"Становая тяга","description":"Базовое упражнение для развития всей задней цепи мышц.","technique":"Встань, ноги на ширине плеч, штанга перед ногами. На вдохе наклонись, сохраняя спину прямой, и возьми штангу. На выдохе поднимай штангу, выпрямляя ноги и корпус.","tips":"Не округляй спину, держи её прямой. Не поднимай штангу слишком высоко, акцент на сокращении мышц. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Задняя цепь, ягодицы, спина","sortOrder":8,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина"},{"id":149,"programId":11,"name":"Подтягивания","description":"Упражнение для развития широчайших мышц спины с акцентом на силу хвата.","technique":"Повиси на перекладине, хват чуть шире плеч. На вдохе подтягивайся вверх, сводя лопатки. На выдохе опускайся обратно.","tips":"Избегай раскачивания, держи тело стабильным. Контролируй движение, избегай резких рывков. Увеличивай количество повторений по мере роста силы.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Широчайшие мышцы спины, бицепсы","sortOrder":9,"exerciseType":"superset","weightAdvice":"Используй собственный вес тела, добавляй отягощение по мере прогресса.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина"},{"id":150,"programId":11,"name":"Приседания со штангой","description":"Базовое упражнение для развития мышц ног и ягодиц.","technique":"Встань, ноги на ширине плеч, штанга на плечах. На вдохе медленно опускайся в присед, сохраняя спину прямой. На выдохе поднимайся обратно в исходное положение.","tips":"Следи за коленями, они не должны выходить за носки. Держи спину прямой, избегай округления. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Квадрицепсы, ягодицы, задняя поверхность бедра","sortOrder":10,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":151,"programId":11,"name":"Жим ногами","description":"Упражнение для изолированной проработки мышц ног.","technique":"Сядь на тренажёр, ноги на платформе. На вдохе опускай платформу, сгибая колени. На выдохе поднимай платформу обратно, выпрямляя ноги.","tips":"Следи за положением коленей, они не должны выходить за носки. Контролируй движение, избегай резких рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Квадрицепсы, ягодицы","sortOrder":11,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":152,"programId":11,"name":"Становая тяга на прямых ногах","description":"Упражнение для проработки задней поверхности бедра и ягодиц.","technique":"Встань, ноги на ширине плеч, штанга перед ногами. На вдохе наклонись вперёд, сохраняя спину прямой, и возьми штангу. На выдохе поднимай штангу, выпрямляя ноги и корпус.","tips":"Не округляй спину, держи её прямой. Контролируй движение, избегай резких рывков. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Задняя поверхность бедра, ягодицы","sortOrder":12,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":153,"programId":11,"name":"Разгибания ног в тренажёре","description":"Изолирующее упражнение для квадрицепсов.","technique":"Сядь на тренажёр, ноги под валиком. На вдохе медленно разгибай ноги, на выдохе возвращай в исходное положение.","tips":"Следи за положением спины, она должна оставаться прижатой к спинке. Контролируй движение, избегай рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Квадрицепсы","sortOrder":13,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":154,"programId":11,"name":"Сгибания ног в тренажёре","description":"Изолирующее упражнение для задней поверхности бедра.","technique":"Ляг на тренажёр, ноги под валиком. На вдохе медленно сгибай ноги, на выдохе возвращай в исходное положение.","tips":"Следи за положением спины, она должна оставаться прижатой к спинке. Контролируй движение, избегай рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Задняя поверхность бедра","sortOrder":14,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":155,"programId":11,"name":"Жим штанги стоя","description":"Базовое упражнение для развития дельтовидных мышц.","technique":"Встань, ноги на ширине плеч, штанга на уровне груди. На вдохе жми штангу вверх, выпрямляя руки. На выдохе опускай штангу обратно.","tips":"Следи за положением спины, она должна оставаться прямой. Не поднимай штангу слишком высоко, акцент на сокращении мышц. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Дельтовидные мышцы","sortOrder":15,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":156,"programId":11,"name":"Разводка гантелей в стороны","description":"Упражнение для развития средней части дельтовидных мышц.","technique":"Встань, ноги на ширине плеч, гантели в руках. На вдохе поднимай руки в стороны, слегка сгибая локти. На выдохе опускай руки обратно.","tips":"Не поднимай руки слишком высоко, акцент на сокращении мышц. Контролируй движение, избегай резких рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Средняя часть дельтовидных мышц","sortOrder":16,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":157,"programId":11,"name":"Тяга штанги к подбородку","description":"Упражнение для развития верхней части дельтовидных мышц.","technique":"Встань, ноги на ширине плеч, штанга перед собой. На вдохе поднимай штангу к подбородку, сводя локти. На выдохе опускай штангу обратно.","tips":"Следи за положением спины, она должна оставаться прямой. Не поднимай штангу слишком высоко, акцент на сокращении мышц. Прогрессируй весом, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Дельтовидные мышцы, трапеция","sortOrder":17,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":158,"programId":11,"name":"Жим гантелей сидя","description":"Упражнение для развития дельтовидных мышц с акцентом на переднюю часть.","technique":"Сядь на скамью, гантели на уровне плеч. На вдохе жми гантели вверх, выпрямляя руки. На выдохе опускай гантели обратно.","tips":"Следи за положением спины, она должна оставаться прямой. Не поднимай гантели слишком высоко, акцент на сокращении мышц. Увеличивай вес, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Дельтовидные мышцы","sortOrder":18,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":159,"programId":11,"name":"Обратные разводки на скамье","description":"Упражнение для проработки задней дельты.","technique":"Ляг на скамью лицом вниз, гантели в руках. На вдохе поднимай руки в стороны, слегка сгибая локти. На выдохе опускай руки обратно.","tips":"Не поднимай руки слишком высоко, акцент на сокращении задней дельты. Контролируй движение, избегай резких рывков. Увеличивай вес, когда сможешь выполнить 12 повторений.","sets":4,"reps":"10-12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Задняя дельта","sortOrder":19,"exerciseType":"superset","weightAdvice":"Выбирай вес, который позволяет выполнить 10-12 повторений.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":160,"programId":11,"name":"Жим узким хватом","description":"Упражнение для проработки трицепсов.","technique":"Ляг на скамью, штанга на уровне груди. На вдохе медленно опускай штангу, локти прижаты к телу. На выдохе поднимай штангу вверх, выпрямляя руки.","tips":"Следи за положением локтей, они должны оставаться прижатыми к телу. Контролируй движение, избегай рывков. Увеличивай вес, когда сможешь выполнить 10 повторений.","sets":4,"reps":"8-10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Трицепсы","sortOrder":20,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ, начни с разминочного подхода на 50%.","circuitGroup":"S5","circuitRounds":null,"dayNumber":5,"dayLabel":"День 5 — Руки + Пресс"}]
