durationSeconds":null,"restSeconds":60,"targetMuscles":"икры","sortOrder":14,"exerciseType":"superset","weightAdvice":"Выбирайте умеренный вес для выполнения 12-15 повторений.","circuitGroup":"S2","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":38,"programId":6,"name":"Жим штанги над головой","description":"Основное упражнение для плеч.","technique":"Жмите штангу вверх, стоя или сидя, с прямой спиной.","tips":"Следите за тем, чтобы локти не выходили за плечи.","sets":3,"reps":"8-12","durationSeconds":null,"restSeconds":60,"targetMuscles":"плечи, трицепсы","sortOrder":15,"exerciseType":"superset","weightAdvice":"Выбирайте вес, который позволяет выполнить 8-12 повторений с правильной техникой.","circuitGroup":"S1","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":39,"programId":6,"name":"Разведения гантелей в стороны","description":"Изолирующее упражнение для плеч.","technique":"Станьте прямо и разводите гантели в стороны до уровня плеч.","tips":"Держите локти чуть согнутыми и не поднимайте гантели выше плеч.","sets":3,"reps":"10-15","durationSeconds":null,"restSeconds":60,"targetMuscles":"плечи","sortOrder":16,"exerciseType":"superset","weightAdvice":"Работайте с легким весом для контроля техники.","circuitGroup":"S1","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":40,"programId":6,"name":"Тяга к подбородку","description":"Упражнение для плеч и верхней части спины.","technique":"Тяните штангу или гантели к подбородку, сохраняя локти выше запястий.","tips":"Не наклоняйтесь вперед и держите спину прямой.","sets":3,"reps":"10-12","durationSeconds":null,"restSeconds":60,"targetMuscles":"плечи, спина","sortOrder":17,"exerciseType":"superset","weightAdvice":"Выбирайте вес для выполнения 10-12 повторений с контролем.","circuitGroup":"S2","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"},{"id":41,"programId":6,"name":"Махи гантелями в стороны","description":"Изолирующее упражнение для средних дельтовидных мышц.","technique":"Встаньте и поднимайте гантели в стороны, сохраняя локти чуть согнутыми.","tips":"Работайте в медленном темпе для контроля.","sets":3,"reps":"10-15","durationSeconds":null,"restSeconds":60,"targetMuscles":"плечи","sortOrder":18,"exerciseType":"superset","weightAdvice":"Используйте легкие веса для точности выполнения.","circuitGroup":"S2","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи"}]
