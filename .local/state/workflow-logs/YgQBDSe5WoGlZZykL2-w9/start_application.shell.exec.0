4:05:23 AM [express] GET /api/training-programs/10/exercises 200 in 712ms :: [{"id":130,"programId":10,"name":"Жим штанги лёжа","description":"Базовое многосуставное упражнение на развитие грудных мышц, передних дельт и трицепсов.","technique":"Ляг на горизонтальную скамью, возьми штангу хватом чуть шире плеч. Опускай штангу к нижней части груди на вдохе, контролируя движение. На выдохе мощно выжимай вверх до полного выпрямления рук. Локти под углом 45° к телу.","tips":"Не отрывай поясницу от скамьи — это защищает спину. Не блокируй локти в верхней точке. Если нет партнёра, не бери слишком тяжёлый вес.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":null,"targetMuscles":"Грудь, трицепс, передние дельты","sortOrder":0,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ. Начни с разминочного подхода на 50%.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь и Трицепс"},{"id":131,"programId":10,"name":"Разводка гантелей лёжа","description":"Изолирующее упражнение на растяжку и сокращение грудных мышц.","technique":"Ляг на горизонтальную скамью с гантелями в руках. Разводи руки в стороны по широкой дуге на вдохе, чуть сгибая локти. Ощути растяжку грудных в нижней точке. Сводя руки обратно на выдохе, представь, что обнимаешь большое дерево.","tips":"Не разгибай локти полностью — держи небольшой изгиб для защиты суставов. Не опускай гантели ниже уровня скамьи. Акцент на ощущении мышцы, а не на весе.","sets":5,"reps":"12","durationSeconds":null,"restSeconds":90,"targetMuscles":"Грудь (широкая часть)","sortOrder":1,"exerciseType":"superset","weightAdvice":"Лёгкий вес, 60-70% усилий. Приоритет — техника и растяжка.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь и Трицепс"},{"id":132,"programId":10,"name":"Тяга штанги в наклоне","description":"Многосуставное упражнение для тренировки мышц спины, бицепсов и задних дельт.","technique":"Встань, ноги на ширине плеч, штанга перед тобой. Наклонись вперёд, сохраняя спину прямой, и возьми штангу хватом чуть шире плеч. На вдохе подтягивай штангу к животу, сводя лопатки. На выдохе опусти штангу в исходное положение.","tips":"Следи за прямой спиной, чтобы избежать травм. Не поднимай штангу слишком высоко, чтобы избежать перерастяжения плечевых суставов. Работай с контролем — плавно.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":null,"targetMuscles":"Спина, бицепсы","sortOrder":2,"exerciseType":"superset","weightAdvice":"70-80% от 1ПМ для хорошей нагрузки.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина и Бицепс"},{"id":133,"programId":10,"name":"Подтягивания","description":"Собственное весовое упражнение для тренировки широчайших мышц спины и бицепсов.","technique":"Повиси на перекладине, хват на ширине плеч. На вдохе подтягивайся вверх, сводя лопатки, пока подбородок не окажется выше перекладины. На выдохе медленно опускайся обратно в исходное положение.","tips":"Не раскачивайся — используй силу спины. Если сложно выполнять, попробуй с помощью резинки. Старайся делать максимально чисто.","sets":5,"reps":"8","durationSeconds":null,"restSeconds":90,"targetMuscles":"Широчайшие мышцы спины, бицепсы","sortOrder":3,"exerciseType":"superset","weightAdvice":"Используй пояс с блинами при необходимости для усложнения.","circuitGroup":"S2","circuitRounds":null,"dayNumber":2,"dayLabel":"День 2 — Спина и Бицепс"},{"id":134,"programId":10,"name":"Приседания со штангой","description":"Базовое упражнение для развития всех мышц ног и ягодиц.","technique":"Встань под штангу, расположенную на плечах. Ноги на ширине плеч, носки слегка наружу. На вдохе сгибай колени и опускайся вниз, сохраняя спину прямой. На выдохе поднимайся обратно в исходное положение.","tips":"Следи, чтобы колени не выходили за носки. Не скругляй спину, держи её ровной. Используй зеркала для самоконтроля.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":null,"targetMuscles":"Квадрицепсы, ягодицы, задняя поверхность бедра","sortOrder":4,"exerciseType":"superset","weightAdvice":"70-80% от 1ПМ. Начни с лёгкого веса для отработки техники.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":135,"programId":10,"name":"Становая тяга","description":"Многосуставное упражнение для тренировки задней поверхности бедра и ягодиц.","technique":"Встань с штангой на полу перед собой. Ноги на ширине плеч, спина прямая. На вдохе наклонись вперёд, сгибая колени и опуская штангу вдоль ног. На выдохе поднимайся, вытягивая бедра вперёд.","tips":"Держи спину прямой на протяжении всего движения. Не округляй поясницу — это может привести к травме. Контролируй вес, чтобы не терять равновесие.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Задняя поверхность бедра, ягодицы, спина","sortOrder":5,"exerciseType":"superset","weightAdvice":"70-80% от 1ПМ. Следи за техникой и прогрессией.","circuitGroup":"S3","circuitRounds":null,"dayNumber":3,"dayLabel":"День 3 — Ноги"},{"id":136,"programId":10,"name":"Жим гантелей сидя","description":"Упражнение для развития дельтовидных мышц и трапеций.","technique":"Сядь на скамью с опорой для спины, гантели в руках на уровне плеч. На вдохе поднимай гантели вверх, выжимая их над головой. На выдохе опускай обратно до уровня плеч.","tips":"Не раздвигай локти слишком широко, держи их под контролем. Избегай резких движений, работай плавно. Убедись, что спина остаётся прямой.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":null,"targetMuscles":"Дельтовидные мышцы, трапеции","sortOrder":6,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ. Начни с лёгкого веса для контроля техники.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи и Трапеции"},{"id":137,"programId":10,"name":"Тяга штанги к подбородку","description":"Упражнение для тренировки дельтовидных мышц и трапеций.","technique":"Встань, ноги на ширине плеч, штанга перед тобой. На вдохе поднимай штангу к подбородку, сгибая локти и сводя их в стороны. На выдохе опускай штангу обратно.","tips":"Не поднимай штангу слишком высоко, чтобы избежать травмы плеч. Следи за прямой спиной и не раскачивайся. Работай в контролируемом темпе.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":90,"targetMuscles":"Дельтовидные мышцы, трапеции","sortOrder":7,"exerciseType":"superset","weightAdvice":"70% от 1ПМ. Обязательно отрабатывай технику.","circuitGroup":"S4","circuitRounds":null,"dayNumber":4,"dayLabel":"День 4 — Плечи и Трапеции"},{"id":138,"programId":10,"name":"Французский жим","description":"Изолирующее упражнение для трицепсов.","technique":"Ляг на скамью, штанга или гантели в руках. На вдохе опускай вес к лбу, сгибая локти. На выдохе поднимай обратно в исходное положение, сохраняя локти неподвижными.","tips":"Не разводи локти в стороны — они должны оставаться параллельно друг другу. Работай с контролем, чтобы избежать травм. Следи за дыханием — оно должно быть ритмичным.","sets":5,"reps":"10","durationSeconds":null,"restSeconds":null,"targetMuscles":"Трицепсы","sortOrder":8,"exerciseType":"superset","weightAdvice":"60-70% от 1ПМ для начала. Увеличивай вес постепенно.","circuitGroup":"S5","circuitRounds":null,"dayNumber":5,"dayLabel":"День 5 — Руки и Пресс"},{"id":139,"programId":10,"name":"Скручивания на пресс","description":"Упражнение для тренировки прямых и косых мышц живота.","technique":"Ляг на пол, ноги согнуты в коленях. На вдохе поднимай верхнюю часть тела к коленям, напрягая пресс. На выдохе опускайся обратно, не касаясь пола.","tips":"Не задирай шею, старайся поднимать корпус только за счёт мышц живота. Не делай резких движений, работай плавно. Увеличивай количество повторений постепенно.","sets":5,"reps":"15","durationSeconds":null,"restSeconds":90,"targetMuscles":"Прямые и косые мышцы живота","sortOrder":9,"exerciseType":"superset","weightAdvice":"Работай с собственным весом для начала. Увеличивай сложность с помощью утяжелителей.","circuitGroup":"S5","circuitRounds":null,"dayNumber":5,"dayLabel":"День 5 — Руки и Пресс"}]
4:05:23 AM [express] GET /api/training-programs/6/exercises 304 in 812ms :: [{"id":23,"programId":6,"name":"Жим штанги на скамье","description":"Основное упражнение для грудных мышц.","technique":"Лягте на скамью, держите штангу на уровне груди и жмите вверх, не отрывая стопы от пола.","tips":"Следите за ровным положением локтей и не закругляйте спину.","sets":3,"reps":"8-12","durationSeconds":null,"restSeconds":60,"targetMuscles":"грудные, трицепсы","sortOrder":0,"exerciseType":"superset","weightAdvice":"Выбирайте вес, который позволяет выполнить 8-12 повторений с правильной техникой.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь и Трицепс"},{"id":24,"programId":6,"name":"Отжимания на брусьях","description":"Упражнение для развития трицепсов и грудных мышц.","technique":"Опуститесь на брусья, сгибая локти, затем поднимитесь в исходное положение.","tips":"Держите тело прямо и не раскачивайтесь.","sets":3,"reps":"8-12","durationSeconds":null,"restSeconds":60,"targetMuscles":"грудные, трицепсы","sortOrder":1,"exerciseType":"superset","weightAdvice":"Используйте дополнительный вес, если можете выполнить более 12 повторений.","circuitGroup":"S1","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь и Трицепс"},{"id":25,"programId":6,"name":"Разведения с гантелями","description":"Изолирующее упражнение для грудных мышц.","technique":"Лягте на скамью и разводите гантели в стороны до уровня плеч.","tips":"Не поднимайте гантели выше линии плеч.","sets":3,"reps":"10-15","durationSeconds":null,"restSeconds":60,"targetMuscles":"грудные","sortOrder":2,"exerciseType":"superset","weightAdvice":"Выбирайте легкие веса для контроля техники.","circuitGroup":"S2","circuitRounds":null,"dayNumber":1,"dayLabel":"День 1 — Грудь и Трицепс"},{"id":26,"programId":6,"name":"Французский жим","description":"Упражнение для трицепсов с гантелями.","technique":"Лягте на скамью, держите гантели над головой и сгибайте локти.","tips":"Не раскачивайте ганте